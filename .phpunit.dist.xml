<?xml version="1.0" encoding="UTF-8"?>

<phpunit
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/9.6/phpunit.xsd"
        backupGlobals="false"
        backupStaticAttributes="false"
        cacheResultFile=".cache/.phpunit.result.cache"
        colors="true"
        convertErrorsToExceptions="true"
        convertNoticesToExceptions="true"
        convertWarningsToExceptions="true"
        processIsolation="false"
        stopOnFailure="false"
        bootstrap="tests/bootstrap.php"
>
    <php>
        <env name="MAGE_IS_DEVELOPER_MODE" value="1"/>
        <env name="NO_XHGUI" value="1"/> <!-- @todo: still needed? -->
    </php>

    <coverage
            includeUncoveredFiles="true"
            processUncoveredFiles="false"
    >
        <include>
            <file>Mage.php</file>
            <directory suffix=".php">app/code</directory>
            <directory suffix=".php">lib</directory>
        </include>
        <exclude>
            <file>app/bootstrap.php</file>
            <directory>app/code/community</directory>
            <directory>app/code/local/</directory>
            <directory>app/code/core/Mage/*/data</directory>
            <directory>app/code/core/Mage/*/sql</directory>
            <directory>vendor</directory>
        </exclude>
        <report>
            <clover outputFile="build/phpunit/report/clover.xml"/>
            <crap4j outputFile="build/phpunit/report/crap4j.xml"/>
        </report>
    </coverage>
    <logging>
        <junit outputFile="build/phpunit/logging/junit.xml"/>
    </logging>

    <extensions>
        <extension class="OpenMage\Tests\Unit\LongRunningTestAlert" />
    </extensions>

    <testsuites>
        <testsuite name="Base">
            <directory>tests/unit/Base</directory>
        </testsuite>
        <testsuite name="Error">
            <directory>tests/unit/Error</directory>
        </testsuite>
        <testsuite name="Mage">
            <directory>tests/unit/Mage</directory>
        </testsuite>

<?xml version="1.0"?>
<!--
/**
 * USA Module Layout
 * 
 * Adds JavaScript for USPS configuration in admin
 */
-->
<layout>
    <!-- Load USPS configuration JavaScript on system config page -->
    <adminhtml_system_config_edit>
        <reference name="head">
            <action method="addItem">
                <type>js</type>
                <name>mage/adminhtml/usps_config.js</name>
            </action>
        </reference>
    </adminhtml_system_config_edit>
</layout>

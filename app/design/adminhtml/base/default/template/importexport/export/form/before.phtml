<script type="text/javascript">
//<![CDATA[
    /**
     * Post form data and process response via AJAX.
     *
     * @return void
     */
    varienForm.prototype.getFilter = function()
    {
        if (document.getElementById('entity') && document.getElementById('entity').value) {
            var url = "<?php echo $this->getUrl('*/*/getFilter') ?>";
            url += ((url.slice(-1) != '/') ? '/' : '') + 'entity/' + document.getElementById('entity').value;

            fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: new URLSearchParams({form_key: FORM_KEY}).toString()
            }).then(function(response) { return response.text(); }).then(function(responseText) {
                var container = document.getElementById('export_filter_grid_container');
                container.innerHTML = responseText.replace(/>\s+</g, '><');
                var scripts = container.querySelectorAll('script');
                for (var s = 0; s < scripts.length; s++) {
                    var scriptEl = document.createElement('script');
                    if (scripts[s].src) {
                        scriptEl.src = scripts[s].src;
                    } else {
                        scriptEl.text = scripts[s].text;
                    }
                    document.head.appendChild(scriptEl).parentNode.removeChild(scriptEl);
                }
                document.getElementById('export_filter_container').style.display = '';
            });
        } else {
            document.getElementById('export_filter_container').style.display = 'none';
        }
    };

    /**
     * Continue export process after filter settings.
     *
     * return void
     */
    function getFile()
    {
        if (document.getElementById('entity') && document.getElementById('file_format')) {
            var form      = document.getElementById('export_filter_form');
            var oldAction = form.action;
            form.action   = oldAction + ((oldAction.slice(-1) != '/') ? '/' : '') + 'entity/' + document.getElementById('entity').value + '/file_format/' + document.getElementById('file_format').value;
            form.submit();
            form.action   = oldAction;
        } else {
            alert('<?php echo Mage::helper('core')->jsQuoteEscape($this->__('Invalid data')) ?>');
        }
    }
//]]>
</script>

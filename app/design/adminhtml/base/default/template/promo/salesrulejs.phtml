<script type="text/javascript">
//<![CDATA[
var couponTypeSpecific = '<?php echo Mage_SalesRule_Model_Rule::COUPON_TYPE_SPECIFIC ?>';
var tmpButtonsActionsStorage = [];

function disableEnableCouponsTabContent(disable) {
    var containerId = 'promo_catalog_edit_tabs_coupons_section_content';
    var container = document.getElementById(containerId);
    if(container){
        var dataFields = container.querySelectorAll('input, select, textarea, button');
        for(var i = 0; i < dataFields.length; i++) {
            dataFields[i].disabled = disable;
            disable ? dataFields[i].classList.add('disabled')
                : dataFields[i].classList.remove('disabled');
        }
    }
    document.getElementById('rule_coupon_code').disabled = !disable;
}

function handleCouponsTabContentActivity() {
    disableEnableCouponsTabContent(!document.getElementById('rule_use_auto_generation').checked);
}

function handleCouponTypeChange() {
    document.getElementById('rule_coupon_type').addEventListener('change', function() {
        var disable = document.getElementById('rule_coupon_type').value != couponTypeSpecific;
        if (!disable) {
            disable = !document.getElementById('rule_use_auto_generation').checked;
        }
        disableEnableCouponsTabContent(disable);
    });
}

function refreshCouponCodesGrid(grid, gridMassAction, transport) {
    grid.reload();
    gridMassAction.unselectAll();
}

function generateCouponCodes(idPrefix, generateUrl, grid) {
    var fieldset = document.getElementById(idPrefix + 'information_fieldset');
    fieldset.classList.remove('ignore-validate');
    var fieldElements = Array.from(fieldset.querySelectorAll('input, select, textarea'));
    var validationResult = fieldElements.map(function(elm) {
        return Validation.validate(elm, {
            useTitle :false,
            onElementValidate : function() {
            }
        });
    }).every(function(v){ return v; });
    fieldset.classList.add('ignore-validate');

    if (!validationResult) {
        return;
    }
    var elements = Array.from(fieldset.querySelectorAll('input, select, textarea'));

    var extra = document.querySelectorAll('#rule_uses_per_coupon, #rule_uses_per_customer, #rule_to_date');
    extra.forEach(function(el){ elements.push(el); });

    var params = new URLSearchParams();
    elements.forEach(function(el) {
        if (!el.name || el.disabled) return;
        if ((el.type === 'checkbox' || el.type === 'radio') && !el.checked) return;
        params.append(el.name, el.value);
    });
    params.append('form_key', FORM_KEY);
    document.getElementById('messages').innerHTML = '';
    var couponCodesGrid = window[grid];
    fetch(generateUrl, {
        method: 'POST',
        headers: {'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest'},
        body: params.toString()
    }).then(function(r) { return r.text(); }).then(function(responseText) {
        var response = {};
        try { response = JSON.parse(responseText); } catch(e) {}

        if (couponCodesGrid) {
            couponCodesGrid.reload();
        }
        if (response && response.messages) {
            document.getElementById('messages').innerHTML = response.messages;
        }
        if (response && response.error) {
            alert(response.error.replace(/<[^>]*>/g, '').toString());
        }
    });
}

if (typeof Ajax !== 'undefined' && Ajax.Responders) {
    Ajax.Responders.register({
        onComplete: function() {
            var el = document.getElementById('promo_catalog_edit_tabs_coupons_section_content');
            if (el
                && el.style.display !== 'none'
                && Ajax.activeRequestCount == 0
            ) {
                handleCouponsTabContentActivity();
            }
        }
    });
}

document.addEventListener("DOMContentLoaded", handleCouponsTabContentActivity);
document.addEventListener("DOMContentLoaded", handleCouponTypeChange);
//]]>
</script>

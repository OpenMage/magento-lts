    <?php echo $this->getBlockHtml('formkey')?>
    <div class="no-display">
        <input type="hidden" id="preview_type" name="type" value="<?php echo $this->isTextType()?1:2 ?>" />
        <input type="hidden" id="preview_text" name="text" value="" />
        <input type="hidden" id="preview_styles" name="styles" value="" />
    </div>
</form>
<script type="text/javascript">
//<![CDATA[
    var templateForm = new varienForm('email_template_edit_form');
    var templatePreviewForm = new varienForm('email_template_preview_form');
    var templateControl = {
        unconvertedText: '',
        typeChange: false,
        variables: null,
        _stripScriptsAndTags: function(html) {
            var tmp = html.replace(/<script[^>]*>[\s\S]*?<\/script>/gi, '');
            tmp = tmp.replace(/<style[^>]*>[\S\s]*?<\/style>/gi, '');
            tmp = tmp.replace(/<[^>]+>/g, '');
            return tmp.trim();
        },
        init: function () {
            var convertBack = document.getElementById('convert_button_back');
            if (convertBack) {
                convertBack.style.display = 'none';
            }
            this.renderPaths(<?php echo $this->getUsedDefaultForPaths(); ?>, 'used_default_for');
            this.renderPaths(<?php echo $this->getUsedCurrentlyForPaths(); ?>, 'used_currently_for');
        },
        stripTags: function () {
            if(!window.confirm("<?php echo Mage::helper('core')->jsQuoteEscape($this->__('Are you sure that you want to strip tags?')) ?>")) {
                return false;
            }
            this.unconvertedText = document.getElementById('template_text').value;
            document.getElementById('convert_button').style.display = 'none';
            document.getElementById('template_text').value = this._stripScriptsAndTags(document.getElementById('template_text').value);
            document.getElementById('convert_button_back').style.display = '';
            document.getElementById('field_template_styles').style.display = 'none';
            this.typeChange = true;
            return false;
        },
        unStripTags: function () {
            document.getElementById('convert_button').style.display = '';
            document.getElementById('convert_button_back').style.display = 'none';
            document.getElementById('template_text').value =  this.unconvertedText;
            document.getElementById('field_template_styles').style.display = '';
            this.typeChange = false;
            return false;
        },
        save: function() {
            if (this.typeChange) {
                document.getElementById('change_flag_element').value = '1';
            }
            templateForm.submit();
            return false;
        },
        preview: function() {
            if (this.typeChange) {
                document.getElementById('preview_type').value = 1;
            } else {
                document.getElementById('preview_type').value = 2;
            }
            if (typeof tinymce == 'undefined' || !tinymce.get('template_text')) {
                document.getElementById('preview_text').value = document.getElementById('template_text').value;
            } else {
                document.getElementById('preview_text').value = tinymce.get('template_text').getContent();
            }

            var templateStyles = document.getElementById('template_styles');
            if (templateStyles != undefined) {
                document.getElementById('preview_styles').value = templateStyles.value;
            }

            templatePreviewForm.submit();
            return false;
        },

        deleteTemplate: function() {
            if(window.confirm("<?php echo Mage::helper('core')->jsQuoteEscape($this->__('Are you sure that you want to delete this template?')) ?>")) {
                   window.location.href = '<?php echo $this->getDeleteUrl() ?>';
            }
        },

        load: function() {
            var form = new varienForm('email_template_load_form');

            if (!form.validator.validate()) {
                return;
            }

            this.variables = null;

            var loadForm = document.getElementById('email_template_load_form');
            var self = this;
            fetch(loadForm.action, {
               method: 'POST',
               headers: {'Content-Type': 'application/x-www-form-urlencoded'},
               body: new URLSearchParams(new FormData(loadForm)).toString()
            }).then(function(resp) { return resp.text(); }).then(function(responseText) {
                   try {
                       var data = JSON.parse(responseText);
                       var keys = Object.keys(data);
                       keys.forEach(function(key) {
                          var el = document.getElementById(key);
                          if (el) {
                              el.value = data[key].trim();
                          }
                          if (key == 'template_type') {
                              if (data[key] == 1) {
                                  self.typeChange = true;
                                  document.getElementById('convert_button').style.display = 'none';
                                  document.getElementById('convert_button_back').style.display = 'none';
                              } else {
                                  self.typeChange = false;
                                  document.getElementById('convert_button_back').style.display = 'none';
                                  document.getElementById('convert_button').style.display = '';
                              }
                          }
                          if (key == 'orig_template_used_default_for') {
                               if(data[key].length){
                                   document.getElementById('used_default_for').style.display = '';
                                   self.renderPaths(data[key], 'used_default_for');
                               }
                               else{
                                   document.getElementById('used_default_for').style.display = 'none';
                               }
                          }
                       });
                   } catch(e) {}
            });

        },

        renderPaths: function(paths, fieldId){
            var field = document.getElementById(fieldId);
            if(field){
                var td = field.querySelector('td');
                if (td) {
                    var nextTd = td.nextElementSibling;
                    if (nextTd) {
                        nextTd.innerHTML = this.parsePath(paths, '<span class="path-delimiter">&nbsp;-&gt;&nbsp;</span>', '<br />');
                    }
                }
            }
        },

        parsePath: function (value, pathDelimiter, lineDelimiter) {
            if (Array.isArray(value)) {
                var result = [];
                for (var i = 0, len = value.length; i < len; i++) {
                    result.push(this.parsePath(value[i], pathDelimiter, pathDelimiter));
                }
                return result.join(lineDelimiter);
            }

            if(typeof value !== 'string' && value.title) {
                value = (value.url ? '<a href="' + value.url + '">' + value.title + '</a>' : value.title) + (value.scope ? '&nbsp;&nbsp;<span class="path-scope-label">(' + value.scope + ')</span>' : '');
            }

            return value;
        },

        openVariableChooser: function() {
            Variables.init('template_text');
            if (this.variables == null) {
                Variables.resetData();
                this.variables = JSON.parse(document.getElementById('variables').value);
                var templateVariablesValue = document.getElementById('template_variables').value;
                if (this.variables && templateVariablesValue) {
                    var templateVariables;
                    if (templateVariables = JSON.parse(templateVariablesValue)) {
                        this.variables.push(templateVariables);
                    }
                }
            }
            if (this.variables) {
                Variables.openVariableChooser(this.variables);
            }
        }
    };

    templateControl.init();
//]]>
</script>

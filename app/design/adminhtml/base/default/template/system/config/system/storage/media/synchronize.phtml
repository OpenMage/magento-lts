/** @var Mage_Adminhtml_Block_System_Config_System_Storage_Media_Synchronize $this */
?>

<script type="text/javascript">
//<![CDATA[
    Validation.add('required-synchronize', '<?php echo Mage::helper('core')->jsQuoteEscape($this->__('Synchronization is required.')) ?>', function(){
        storage = getConnectionName(
            document.getElementById('system_media_storage_configuration_media_storage').value,
            document.getElementById('system_media_storage_configuration_media_database').value
        );

        return allowedStorages.indexOf(storage) !== -1;
    });

    defaultValues   = [];
    defaultValues['system_media_storage_configuration_media_storage']   = document.getElementById('system_media_storage_configuration_media_storage').value;
    defaultValues['system_media_storage_configuration_media_database']  = document.getElementById('system_media_storage_configuration_media_database').value;

    allowedStorages = [];
    addAllowedStorage(
        document.getElementById('system_media_storage_configuration_media_storage').value,
        document.getElementById('system_media_storage_configuration_media_database').value
    );

    <?php $syncStorageParams = $this->getSyncStorageParams() ?>
    addAllowedStorage(<?php echo $syncStorageParams['storage_type'] ?>, '<?php echo $syncStorageParams['connection_name'] ?>');

    function getConnectionName(storageType, connection)
    {
        if (storageType == 0) {
            return storageType;
        } else if (connection != '') {
            return storageType + '_' + connection;
        }

        return '';
    }

    function addAllowedStorage(storageType, connection)
    {
        storage = getConnectionName(storageType, connection);

        if (storage != '' && !allowedStorages.indexOf(storage) !== -1) {
            allowedStorages.push(storage);
        }
    }

    function checkButtonState(event) {
        var element = event.target;

        defaultStorage = getConnectionName(
            defaultValues['system_media_storage_configuration_media_storage'],
            defaultValues['system_media_storage_configuration_media_database']
        );

        storage = getConnectionName(
            document.getElementById('system_media_storage_configuration_media_storage').value,
            document.getElementById('system_media_storage_configuration_media_database').value
        );

        if (defaultStorage != storage) {
            enableSyncButton();
        } else {
            disableSyncButton();
        }
    }

    function enableStorageSelection() {
        document.getElementById('system_media_storage_configuration_media_storage').disabled = false;
        document.getElementById('system_media_storage_configuration_media_database').disabled = false;
    }

    function disableStorageSelection() {
        document.getElementById('system_media_storage_configuration_media_storage').disabled = true;
        document.getElementById('system_media_storage_configuration_media_database').disabled = true;
    }

    function enableSyncButton() {
        document.getElementById('synchronize_button').disabled = false;
        document.getElementById('synchronize_button').classList.remove('disabled');
    }

    function disableSyncButton() {
        document.getElementById('synchronize_button').disabled = true;
        document.getElementById('synchronize_button').classList.add('disabled');
    }

    window.addEventListener('load', function(){
        disableStorageSelection();
        disableSyncButton();
        checkStatus();
    });
    document.getElementById('system_media_storage_configuration_media_storage').addEventListener('change', checkButtonState);
    document.getElementById('system_media_storage_configuration_media_database').addEventListener('change', checkButtonState);

    function checkStatus() {
        var intervalId = setInterval(function() {
            fetch('<?php echo $this->getAjaxStatusUpdateUrl() ?>', {
                method: 'GET'
            }).then(function(resp) { return resp.json(); }).then(function(response) {
                try {
                    if (response.state == '<?php echo Mage_Core_Model_File_Storage_Flag::STATE_RUNNING ?>'
                        && response.message
                    ) {
                        var syncSpan = document.getElementById('sync_span');
                        if (syncSpan.classList.contains('no-display')) {
                            syncSpan.classList.remove('no-display');
                            document.getElementById('sync_message_span').innerHTML = response.message;
                        }
                    } else {
                        clearInterval(intervalId);
                        enableStorageSelection();
                        document.getElementById('sync_span').classList.add('no-display');

                        if (response.state == '<?php echo Mage_Core_Model_File_Storage_Flag::STATE_NOTIFIED ?>') {
                            if (response.html && response.html != '') {
                                document.querySelectorAll('div.notification-global').forEach(function(e) {
                                    if (!e.classList.contains('notification-global-notice')) {
                                        e.style.display = 'none';
                                    }
                                });

                                document.getElementById('anchor-content').insertAdjacentHTML('beforebegin', response.html);
                            }

                            if (response.has_errors) {
                                enableSyncButton();
                            } else {
                                addAllowedStorage(
                                    document.getElementById('system_media_storage_configuration_media_storage').value,
                                    document.getElementById('system_media_storage_configuration_media_database').value
                                );
                            }
                        }
                    }
                } catch (e) {}
            }).catch(function() {});
        }, 5000);
    }

    function synchronize() {
        var advice = Validation.getAdvice('required-synchronize', document.getElementById('synchronize-validation-input'));
        if (advice) {
            advice.style.display = 'none';
        }
        var params = {
            storage:    document.getElementById('system_media_storage_configuration_media_storage').value,
            connection: document.getElementById('system_media_storage_configuration_media_database').value
        };

        fetch('<?php echo $this->getAjaxSyncUrl() ?>', {
            method: 'POST',
            headers: {'Content-Type': 'application/x-www-form-urlencoded'},
            body: new URLSearchParams(params).toString()
        });

        window.setTimeout(checkStatus, 2011);

        disableStorageSelection();
        disableSyncButton();
    }
//]]>
</script>

<?php echo $this->getButtonHtml() ?><span class="sync-indicator no-display" id="sync_span"><img alt="Synchronize" style="margin:0 5px" src="<?php echo $this->getSkinUrl('images/process_spinner.gif') ?>"/><span id="sync_message_span"></span></span>
<input type="hidden" id="synchronize-validation-input" class="required-synchronize no-display"/>

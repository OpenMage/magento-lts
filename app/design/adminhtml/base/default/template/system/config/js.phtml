<script type="text/javascript">
//<![CDATA[
var freeModel = function() {
    this.reload = false;
    this.bindFreeMethodCutoffCostRelation();
};
freeModel.prototype = {
    bindFreeMethodCutoffCostRelation : function(parentId)
    {
        if(parentId) {
            var freeMethodElements = document.querySelectorAll('#'+parentId+' .free-method');
        } else {
            var freeMethodElements = document.querySelectorAll('.free-method');
        }
        for(var i=0;i<freeMethodElements.length; i++) {
            freeMethodElements[i].addEventListener('change', this.checkFreeMethod.bind(this));
            this.initFreeMethod(freeMethodElements[i]);
        }
    },
    initFreeMethod : function(element)
    {
        var freeMethodElement = element;

        if (freeMethodElement && freeMethodElement.id) {
            var cutoffElement  = document.getElementById(freeMethodElement.id.replace(/free_method/, 'cutoff_cost'));
            if (cutoffElement) {
                if (freeMethodElement.value == '') {
                    cutoffElement.disabled = true;
                } else {
                    cutoffElement.disabled = false;
                }
            }
        }
    },
    checkFreeMethod : function(event)
    {
        var freeMethodElement = event.target;
        if (freeMethodElement && freeMethodElement.id) {
            var cutoffElement  = document.getElementById(freeMethodElement.id.replace(/free_method/, 'cutoff_cost'));
            if (cutoffElement) {
                if (freeMethodElement.value == '') {
                    cutoffElement.disabled = true;
                } else {
                    cutoffElement.disabled = false;
                }
            }
        }
    }
}

freeMethod = new freeModel();

var originModel = function() {
    this.reload = false;
    this.loader = new varienLoader(true);
    this.regionsUrl = "<?php echo $this->getUrl('*/json/countryRegion') ?>";

    this.bindCountryRegionRelation();
};
originModel.prototype = {
    bindCountryRegionRelation : function(parentId)
    {
        if(parentId) {
            var countryElements = document.querySelectorAll('#'+parentId+' .countries');
        } else {
            var countryElements = document.querySelectorAll('.countries');
        }
        for(var i=0; i<countryElements.length; i++) {
            countryElements[i].addEventListener('change', this.reloadRegionField.bind(this));
            this.initRegionField(countryElements[i]);
            var inheritEl = document.getElementById(countryElements[i].id+'_inherit');
            if (inheritEl) {
                inheritEl.addEventListener('change', this.enableRegionZip.bind(this));
            }
        }
    },
    enableRegionZip : function(event)
    {
        this.reload = true;
        var countryElement = event.target;
        if (countryElement && countryElement.id && !countryElement.checked) {
            var regionElement  = document.getElementById(countryElement.id.replace(/country_id/, 'region_id'));
            var zipElement  = document.getElementById(countryElement.id.replace(/country_id/, 'postcode'));
            if (regionElement && regionElement.checked) {
                regionElement.click();
            }
            if (zipElement && zipElement.checked) {
                zipElement.click();
            }
        }
    },
    initRegionField : function(element)
    {
        var countryElement = element;
        if (countryElement && countryElement.id) {
            var regionElement  = document.getElementById(countryElement.id.replace(/country_id/, 'region_id'));
            if (regionElement) {
                this.regionElement = regionElement;
                var url = this.regionsUrl+'parent/'+countryElement.value;
                this.loader.load(url, {}, this.refreshRegionField.bind(this));
            }
        }
    },
    reloadRegionField : function(event)
    {
        this.reload = true;
        var countryElement = event.target;
        if (countryElement && countryElement.id) {
            var regionElement  = document.getElementById(countryElement.id.replace(/country_id/, 'region_id'));
            if (regionElement) {
                this.regionElement = regionElement;
                var url = this.regionsUrl+'parent/'+countryElement.value;
                this.loader.load(url, {}, this.refreshRegionField.bind(this));
            }
        }
    },
    refreshRegionField : function(serverResponse)
    {
        if (serverResponse) {
            var data = JSON.parse(serverResponse);
            var value = this.regionElement.value;
            var disabled = this.regionElement.disabled;
            if (data.length) {
                var html = '<select name="'+this.regionElement.name+'" id="'+this.regionElement.id+'" class="required-entry select" title="'+this.regionElement.title+'"'+(disabled?" disabled":"")+'>';
                for (var i in data) {
                    if(data[i].label) {
                        html+= '<option value="'+data[i].value+'"';
                        if(this.regionElement.value && (this.regionElement.value == data[i].value || this.regionElement.value == data[i].label)) {
                            html+= ' selected';
                        }
                        html+='>'+data[i].label+'<\/option>';
                    }
                }
                html+= '<\/select>';

                var parentNode = this.regionElement.parentNode;
                var regionElementId = this.regionElement.id;
                parentNode.innerHTML = html;
                this.regionElement = document.getElementById(regionElementId);
            } else if (this.reload) {
                var html = '<input type="text" name="'+this.regionElement.name+'" id="'+this.regionElement.id+'" class="input-text" title="'+this.regionElement.title+'"'+(disabled?" disabled":"")+'>';
                var parentNode = this.regionElement.parentNode;
                var regionElementId = this.regionElement.id;
                parentNode.innerHTML = html;
                this.regionElement = document.getElementById(regionElementId);
            }
        }
    }
}

originAddress = new originModel();

var perPageModel = function() {
    this.listModeElement = document.getElementById('catalog_frontend_list_mode');
    if (this.listModeElement) {
        this.gridValuesElement = document.getElementById('catalog_frontend_grid_per_page_values');
        this.listValuesElement = document.getElementById('catalog_frontend_list_per_page_values');
        this.listElement = document.getElementById('catalog_frontend_list_per_page');
        this.gridElement = document.getElementById('catalog_frontend_grid_per_page');

        this.gridOptions = [];
        this.listOptions = [];

        this.refreshPerPageSelect();
        this.bindListModeChange();
    }
    this.addValidate();
};

perPageModel.prototype = {
    _getAncestorRow : function(el) {
        var parent = el;
        for (var i = 0; i < 1 && parent; i++) {
            parent = parent.parentNode;
        }
        return parent;
    },
    bindListModeChange : function()
    {
        this.listModeElement.addEventListener('change', this.refreshPerPageSelect.bind(this));
    },
    refreshPerPageSelect : function()
    {
        if (this.listModeElement.value != '') {
            if (this.listModeElement.value == 'grid') {
                this._getAncestorRow(this.listElement).style.display = 'none';
                this._getAncestorRow(this.listValuesElement).style.display = 'none';

                this._getAncestorRow(this.gridElement).style.display = '';
                this._getAncestorRow(this.gridValuesElement).style.display = '';
            }
            else if (this.listModeElement.value == 'grid-list' || this.listModeElement.value == 'list-grid') {
                this._getAncestorRow(this.listElement).style.display = '';
                this._getAncestorRow(this.listValuesElement).style.display = '';

                this._getAncestorRow(this.gridElement).style.display = '';
                this._getAncestorRow(this.gridValuesElement).style.display = '';
            }
            else if (this.listModeElement.value == 'list') {
                this._getAncestorRow(this.listElement).style.display = '';
                this._getAncestorRow(this.listValuesElement).style.display = '';

                this._getAncestorRow(this.gridElement).style.display = 'none';
                this._getAncestorRow(this.gridValuesElement).style.display = 'none';
            }
        }
    },
    addValidate : function()
    {
        Validation.add('validate-per-page-value-list', '<?php echo Mage::helper('core')->jsQuoteEscape($this->__('Please enter a valid value, ex: 10,20,30')) ?>', function(v) {
            var isValid = !Validation.get('IsEmpty').test(v);
            var values  = v.split(',');
            for (var i=0;i<values.length;i++) {
                if (!/^[0-9]+$/.test(values[i])) {
                    isValid = false;
                }
            }
            return isValid;
        });
        Validation.add('validate-per-page-value', '<?php echo Mage::helper('core')->jsQuoteEscape($this->__('Please enter a valid value from list')) ?>', function(v, elm) {
            if (Validation.get('IsEmpty').test(v)) {
                return false;
            }
            var values = document.getElementById(elm.id + '_values').value.split(',');
            return values.indexOf(v) != -1;
        });
    }
}

perPageSelect = new perPageModel();

function showHint() {
    document.querySelectorAll('.hint').forEach(function(element){
        element.addEventListener('mouseover', function(){
            var child = element.querySelector(':first-child');
            if (child) child.style.display = '';
        });
        element.addEventListener('mouseout', function(){
            var child = element.querySelector(':first-child');
            if (child) child.style.display = 'none';
        });
    });
}
window.addEventListener('load', function(){
    showHint();
});
//]]>
</script>

                if (cb.checked && cb.name) {
                    params.append(cb.name, cb.value);
                }
            });
            Object.keys(extraParams).forEach(function (k) { params.append(k, extraParams[k]); });
            params.append('form_key', FORM_KEY);

            var container = document.getElementById('problemGrid');
            fetch(problemGridJsObject.url + '?ajax=1', {
                method: 'POST',
                headers: {'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest'},

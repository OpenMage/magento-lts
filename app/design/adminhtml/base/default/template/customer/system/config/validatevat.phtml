<?php
/**
 * @see Mage_Adminhtml_Block_Customer_System_Config_Validatevat
 * @var Mage_Adminhtml_Block_Customer_System_Config_Validatevat $this
 */
?>
<script type="text/javascript">
//<![CDATA[
    function validateVat() {
        var elem = document.getElementById('<?php echo $this->getHtmlId() ?>');

        params = {
            country: document.getElementById('general_store_information_merchant_country').value,
            vat: document.getElementById('general_store_information_merchant_vat_number').value
        };

        fetch('<?php echo $this->getAjaxUrl() ?>', {
            method: 'POST',
            headers: {'Content-Type': 'application/x-www-form-urlencoded'},
            body: new URLSearchParams(params).toString()
        }).then(function(r) { return r.text(); }).then(function(responseText) {
            var result = '<?php echo Mage::helper('core')->jsQuoteEscape($this->__('VAT Number is Invalid')) ?>';
            try {
                if (responseText == 1) {
                    result = '<?php echo Mage::helper('core')->jsQuoteEscape($this->__('VAT Number is Valid')) ?>';
                    elem.classList.remove('fail'); elem.classList.add('success');
                } else {
                    elem.classList.remove('success'); elem.classList.add('fail');
                }
            } catch (e) {
                elem.classList.remove('success'); elem.classList.add('fail');
            }
            document.getElementById('validation_result').innerHTML = result;
        });
    }
//]]>
</script>
<button onclick="javascript:validateVat(); return false;" class="scalable" type="button" id="<?php echo $this->getHtmlId() ?>">
    <span id="validation_result"><?php echo $this->escapeHtml($this->getButtonLabel()) ?></span>
</button>

<script type="text/javascript">
//<![CDATA[
    categoryForm = new varienForm('category_edit_form');

    categoryForm.submit= function (url) {
        this.errorSections = {};
        this.canShowError = true;
        this.submitUrl = url;
        if (this.validator && this.validator.validate()) {
            if(this.validationUrl){
                this._validate();
            }
            else{
                if (this.isSubmitted) {
                    return false;
                }
                this.isSubmitted = true;
                this._submit();
            }
            displayLoadingMask();
            return true;
        }
        return false;
    };

    categoryForm.refreshPath = function () {

        categoryId = this.getCategoryId();

        if (!categoryId) {
            return false;
        }

        var refreshPathSuccess = function(transport) {
            var isJson = false; try { JSON.parse(transport.responseText); isJson = true; } catch(e) {}
            if (isJson) {
                response = JSON.parse(transport.responseText);
                if (response.error) {
                    alert(response.message);
                } else {
                    if (categoryForm.getCategoryId() == response['id']) {
                        categoryForm.setCategoryPath(response['path']);
                    }
                }
            }
        };

        fetch('<?php echo $this->getRefreshPathUrl() ?>', {
            method: 'POST',
            headers: {'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest'},
            body: new URLSearchParams({form_key: FORM_KEY}).toString()
        }).then(function(resp) { return resp.text(); }).then(function(text) {
            refreshPathSuccess({responseText: text});
        });

    };

    categoryForm.getCategoryId = function () {
        var collection = document.getElementById(this.formId).querySelectorAll('input[type="hidden"][name="general[id]"]');
        if (collection.length > 0) {
            return collection[0].value;
        }
        return false;
    };

    categoryForm.setCategoryPath = function (path) {
        var collection = document.getElementById(this.formId).querySelectorAll('input[type="hidden"][name="general[path]"]');
        if (collection.length > 0) {
            return collection[0].value = path;
        }
    };

    /**
    * Create/edit some category
    */
    function categorySubmit(url, useAjax) {
        var activeTab = document.getElementById('active_tab_id');
        if (activeTab) {
            if (activeTab.tabsJsObject && activeTab.tabsJsObject.activeTab) {
                activeTab.value = activeTab.tabsJsObject.activeTab.id;
            }
        }

        var params = {};
        var fields = document.getElementById('category_edit_form').querySelectorAll('input, select');
        for(var i=0;i<fields.length;i++){
            if (!fields[i].name) {
                continue;
            }
            params[fields[i].name] = fields[i].value;
        }

        // Get info about what we're submitting - to properly update tree nodes
        var categoryId = params['general[id]'] ? params['general[id]'] : 0;
        var isCreating = categoryId == 0; // Separate variable is needed because '0' in javascript converts to TRUE
        var path = params['general[path]'].split('/');
        var parentId = path.pop();
        if (parentId == categoryId) { // Maybe path includes category id itself
            parentId = path.pop();
        }

        // Make operations with category tree
        if (isCreating) {
            /* Some specific tasks for creating category */
            if (!tree.currentNodeId) {
                // First submit of form - select some node to be current
                tree.currentNodeId = parentId;
            }
            tree.addNodeTo = parentId;
        } else {
            /* Some specific tasks for editing category */
            // Maybe change category enabled/disabled style
            if (tree && tree.storeId==0) {
                var currentNode = tree.getNodeById(categoryId);

                if (currentNode) {
                    if (parseInt(params['general[is_active]'])) {
                        var oldClass = 'no-active-category';
                        var newClass = 'active-category';
                    } else {
                        var oldClass = 'active-category';
                        var newClass = 'no-active-category';
                    }

                    currentNode.ui.wrap.firstChild.classList.remove(oldClass);
                    currentNode.ui.wrap.firstChild.classList.add(newClass);
                }
            }
        }

        // Submit form
        categoryForm.submit();
    }

<?php if(($block = $this->getLayout()->getBlock('category.product.grid')) && ($_gridJsObject=$block->getJsObjectName())): ?>

    var categoryProducts = new Map(Object.entries(<?php echo $this->getProductsJson() ?>));
    document.getElementById('in_category_products').value = Array.from(categoryProducts).map(function(p) { return encodeURIComponent(p[0]) + '=' + encodeURIComponent(p[1]); }).join('&');

    function registerCategoryProduct(grid, element, checked){
        if(checked){
            if(element.positionElement){
                element.positionElement.disabled = false;
                categoryProducts.set(element.value, element.positionElement.value);
            }
        }
        else{
            if(element.positionElement){
                element.positionElement.disabled = true;
            }
            categoryProducts.delete(element.value);
        }
        document.getElementById('in_category_products').value = Array.from(categoryProducts).map(function(p) { return encodeURIComponent(p[0]) + '=' + encodeURIComponent(p[1]); }).join('&');
        grid.reloadParams = {'selected_products[]':Array.from(categoryProducts.keys())};
    }
    function categoryProductRowClick(grid, event){
        var tdElement = event.target.closest('td');
        var isInput   = event.target.tagName == 'INPUT';
        if(tdElement){
            var checkbox = tdElement.querySelectorAll('input');
            if(checkbox[0]){
                var checked = isInput ? checkbox[0].checked : !checkbox[0].checked;
                <?php echo $_gridJsObject ?>.setCheckboxChecked(checkbox[0], checked);
            }
        }
    }
    function positionChange(event){
        var element = event.target;
        if(element && element.checkboxElement && element.checkboxElement.checked){
            categoryProducts.set(element.checkboxElement.value, element.value);
            document.getElementById('in_category_products').value = Array.from(categoryProducts).map(function(p) { return encodeURIComponent(p[0]) + '=' + encodeURIComponent(p[1]); }).join('&');
        }
    }

    var tabIndex = 1000;
    function categoryProductRowInit(grid, row){
        var rowEl = (typeof row === 'string') ? document.getElementById(row) : row;
        var checkbox = rowEl.getElementsByClassName('checkbox')[0];
        var position = rowEl.getElementsByClassName('input-text')[0];
        if(checkbox && position){
            checkbox.positionElement = position;
            position.checkboxElement = checkbox;
            position.disabled = !checkbox.checked;
            position.tabIndex = tabIndex++;
            position.addEventListener('keyup',positionChange);
        }
    }


    <?php echo $_gridJsObject ?>.rowClickCallback = categoryProductRowClick;
    <?php echo $_gridJsObject ?>.initRowCallback = categoryProductRowInit;
    <?php echo $_gridJsObject ?>.checkboxCheckCallback = registerCategoryProduct;
    <?php echo $_gridJsObject ?>.rows.each(function(row){categoryProductRowInit(<?php echo $_gridJsObject ?>, row)});

<?php endif ?>
<?php if($this->isAjax() && ($block = $this->getLayout()->getBlock('tabs')) && ($_tabsJsObject=$block->getJsObjectName())): ?>
    <?php echo $_tabsJsObject ?>.moveTabContentInDest();
    if (<?php echo $_tabsJsObject ?>.activeTab) {
        document.getElementById('active_tab_id').value = <?php echo $_tabsJsObject ?>.activeTab.id;
    }
    document.getElementById('active_tab_id').tabsJsObject = <?php echo $_tabsJsObject ?>;
<?php endif ?>
//]]>
</script>

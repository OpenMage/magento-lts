/** @var Mage_Adminhtml_Block_Catalog_Product_Edit_Tab_Options_Option $this */
?>
<?php echo $this->getTemplatesHtml() ?>

<script type="text/javascript">
//<![CDATA[
var firstStepTemplate = '<div class="option-box" id="option_{{id}}">'+
            '<table id="<?php echo $this->getFieldId() ?>_{{id}}" class="option-header" cellpadding="0" cellspacing="0">'+
            '<input type="hidden" id="<?php echo $this->getFieldId() ?>_{{id}}_is_delete" name="<?php echo $this->getFieldName() ?>[{{id}}][is_delete]" value="" />'+
            '<input type="hidden" id="<?php echo $this->getFieldId() ?>_{{id}}_previous_type" name="<?php echo $this->getFieldName() ?>[{{id}}][previous_type]" value="{{type}}" />'+
            '<input type="hidden" id="<?php echo $this->getFieldId() ?>_{{id}}_previous_group" name="<?php echo $this->getFieldName() ?>[{{id}}][previous_group]" value="" />'+
            '<input type="hidden" id="<?php echo $this->getFieldId() ?>_{{id}}_id" name="<?php echo $this->getFieldName() ?>[{{id}}][id]" value="{{id}}" />'+
            '<input type="hidden" id="<?php echo $this->getFieldId() ?>_{{id}}_option_id" name="<?php echo $this->getFieldName() ?>[{{id}}][option_id]" value="{{option_id}}" />'+
            '<thead>'+
                '<tr>'+
                    '<th class="opt-title"><?php echo $this->jsQuoteEscape(Mage::helper('catalog')->__('Title')) ?> <span class="required">*</span></th>'+
                    '<th class="opt-type"><?php echo $this->jsQuoteEscape(Mage::helper('catalog')->__('Input Type')) ?> <span class="required">*</span></th>'+
                    '<th class="opt-req"><?php echo $this->jsQuoteEscape(Mage::helper('catalog')->__('Is Required')) ?></th>'+
                    '<th class="opt-order"><?php echo $this->jsQuoteEscape(Mage::helper('catalog')->__('Sort Order')) ?></th>'+
                    '<th class="a-right"><?php echo $this->jsQuoteEscape($this->jsQuoteEscape($this->getDeleteButtonHtml())) ?></th>'+
                '</tr>'+
            '</thead>'+
            '<tr>'+
                '<td><input type="text" class="required-entry input-text" id="<?php echo $this->getFieldId() ?>_{{id}}_title" name="<?php echo $this->getFieldName() ?>[{{id}}][title]" value="{{title}}">{{checkboxScopeTitle}}</td>'+
                '<td><?php echo $this->getTypeSelectHtml() ?></td>'+
                '<td class="opt-req"><?php echo $this->getRequireSelectHtml() ?></td>'+
                '<td><input type="text" class="validate-zero-or-greater input-text" name="<?php echo $this->getFieldName() ?>[{{id}}][sort_order]" value="{{sort_order}}"></td>'+
                '<td>&nbsp;</td>'+
            '</tr></table></div>';

var productOption = {
    div : document.getElementById('product_options_container_top'),
    templateSyntax : /(^|.|\r|\n)({{(\w+)}})/,
    templateText : firstStepTemplate,
    itemCount : 1,
    add : function(data) {
        var _tplText = this.templateText, _syntax = this.templateSyntax;
        this.template = { evaluate: function(obj) { return _tplText.replace(new RegExp(_syntax.source, 'g'), function(m, p1, p2, p3) { return p1 + (obj[p3] !== undefined ? obj[p3] : ''); }); } };

        if(!data.id){
            data = {};
            data.id  = this.itemCount;
            data.type = '';
            data.option_id = 0;
        } else {
            this.itemCount = data.item_count;
        }

        this.div.insertAdjacentHTML('afterend', this.template.evaluate(data));

        //set selected type
        if (data.type) {
            Array.from(document.getElementById('<?php echo $this->getFieldId() ?>_'+data.id+'_type').options).forEach(function(option){
                if (option.value==data.type) option.selected = true;
            });
        }

        //set selected is_require
        if (data.hasOwnProperty('is_require')) {
            Array.from(document.getElementById('<?php echo $this->getFieldId() ?>_'+data.id+'_is_require').options).forEach(function(option){
                if (option.value==data.is_require) option.selected = true;
            });
        }

        if (data.checkboxScopeTitle) {
            //set disabled
            if (document.getElementById('<?php echo $this->getFieldId() ?>_'+data.option_id+'_title') && data.scopeTitleDisabled) {
                document.getElementById('<?php echo $this->getFieldId() ?>_'+data.option_id+'_title').disabled = true;
            }
        }

        this.itemCount++;
        this.bindRemoveButtons();
        productOptionType.bindSelectInputType();
    },
    remove : function(event){
        var element = event.target.closest('div');
        if(element){
            document.getElementById('product_'+element.getAttribute('id')+'_'+'is_delete').value = '1';
            element.classList.add('no-display');
            element.classList.add('ignore-validate');
            element.style.display = 'none';
        }
    },
    bindRemoveButtons : function(){
        var buttons = document.querySelectorAll('div.product-custom-options .delete-product-option');
        for(var i=0;i<buttons.length;i++){
            if(!buttons[i].binded){
                buttons[i].binded = true;
                buttons[i].addEventListener('click', this.remove.bind(this));
            }
        }
        var inputs = document.querySelectorAll('div.product-custom-options button, div.product-custom-options input, div.product-custom-options select, div.product-custom-options textarea');
        <?php if ($this->isReadonly()):?>
        for (var i=0, l = inputs.length; i < l; i ++) {
            inputs[i].disabled = true;
            if (inputs[i].tagName.toLowerCase()=='button') {
                inputs[i].classList.add('disabled');
            }
        }
        <?php else: ?>
            inputs.forEach(function(el) { el.addEventListener('change', el.setHasChanges.bind(el));  } )
            var inputs = document.querySelectorAll('div.product-custom-options button');
            inputs.forEach(function(el) { el.addEventListener('click', el.setHasChanges.bind(el));  } )
        <?php endif ?>
    }
}


var productOptionType = {
    templateSyntax : /(^|.|\r|\n)({{(\w+)}})/,
    loadStepTwo : function(event){
        var element = event.target.closest('select');

        var group = '';
        var previousGroupElm = document.getElementById(element.getAttribute('id').replace('_type', '_previous_group'));

        switch(element.value){
            case 'field':
            case 'area':
                template = OptionTemplateText;
                group = 'text';
                break;
            case 'file':
                template = OptionTemplateFile;
                group = 'file';
                break;
            case 'drop_down':
            case 'radio':
            case 'checkbox':
            case 'multiple':
                template = OptionTemplateSelect;
                group = 'select';
                break;
            case 'date':
            case 'date_time':
            case 'time':
                template = OptionTemplateDate;
                group = 'date';
                break;
            default:
                template = '';
                group = 'unknown';
                break;
        }

        if (previousGroupElm.value != group) {
            var elId = element.getAttribute('id');
            if (document.getElementById(elId+'_'+previousGroupElm.value)) {
                var prevGroupEl = document.getElementById(elId+'_'+previousGroupElm.value);
                Array.from(prevGroupEl.querySelectorAll('*')).forEach(function(elm){
                    if (elm.tagName.toLowerCase() == 'input' || elm.tagName.toLowerCase() == 'select') {
                        elm.name = '__delete__'+elm.getAttribute('name');
                    }
                });

                prevGroupEl.classList.add('no-display');
                prevGroupEl.classList.add('ignore-validate');
                prevGroupEl.style.display = 'none';
            }

            previousGroupElm.value = group;

            if (document.getElementById(elId+'_'+group)) {
                var groupEl = document.getElementById(elId+'_'+group);
                Array.from(groupEl.querySelectorAll('*')).forEach(function(elm){
                    if (elm.tagName.toLowerCase() == 'input' || elm.tagName.toLowerCase() == 'select') {
                        elm.name = elm.getAttribute('name').replace('__delete__', '');
                    }
                });
                groupEl.classList.remove('no-display');
                groupEl.classList.remove('ignore-validate');
                groupEl.style.display = '';

            } else {
                template = '<div id="'+elId+'_'+group+'" class="grid tier form-list">'+template+'</div><div id="'+elId+'_'+group+'_advice"></div>';
                var _syntax2 = this.templateSyntax;
                this.secondTemplate = { evaluate: function(obj) { return template.replace(new RegExp(_syntax2.source, 'g'), function(m, p1, p2, p3) { return p1 + (obj[p3] !== undefined ? obj[p3] : ''); }); } };

                data = {};
                if (!data.option_id) {
                    data = {};
                    data.option_id = document.getElementById(elId.replace('_type', '_id')).value;
                }

                var insertTarget = document.getElementById(elId.replace('_type', ''));
                insertTarget.insertAdjacentHTML('afterend', this.secondTemplate.evaluate(data));

                switch(element.getValue()){
                    case 'drop_down':
                    case 'radio':
                    case 'checkbox':
                    case 'multiple':
                        selectOptionType.bindAddButton();
                        break;
                }
            }
        }
    },
    addDataToValues : function(data){

        switch(data.type){
            case 'field':
            case 'area':
                template = OptionTemplateText;
                group = 'text';
                break;
            case 'file':
                template = OptionTemplateFile;
                group = 'file';
                break;
            case 'drop_down':
            case 'radio':
            case 'checkbox':
            case 'multiple':
                template = OptionTemplateSelect;
                group = 'select';
                break;
            case 'date':
            case 'date_time':
            case 'time':
                template = OptionTemplateDate;
                group = 'date';
                break;
        }

        document.getElementById('<?php echo $this->getFieldId() ?>_'+data.id+'_previous_group').value = group;

        template = '<div id="<?php echo $this->getFieldId() ?>_{{id}}_type_'+group+'" class="grid tier form-list">'+template+'</div><div id="<?php echo $this->getFieldId() ?>_{{id}}_type_'+group+'_advice"></div>';

        var _syntax3 = this.templateSyntax;
        this.secondTemplate = { evaluate: function(obj) { return template.replace(new RegExp(_syntax3.source, 'g'), function(m, p1, p2, p3) { return p1 + (obj[p3] !== undefined ? obj[p3] : ''); }); } };

        var insertTarget2 = document.getElementById('<?php echo $this->getFieldId() ?>_'+data.option_id);
        insertTarget2.insertAdjacentHTML('afterend', this.secondTemplate.evaluate(data));

        if (data.checkboxScopePrice) {
            //set disabled
            if (document.getElementById('<?php echo $this->getFieldId() ?>_'+data.option_id+'_price') && data.scopePriceDisabled) {
                document.getElementById('<?php echo $this->getFieldId() ?>_'+data.option_id+'_price').disabled = true;
                document.getElementById('<?php echo $this->getFieldId() ?>_'+data.option_id+'_price_type').disabled = true;
            }
        }

        switch(data.type){
            case 'drop_down':
            case 'radio':
            case 'checkbox':
            case 'multiple':
                data.optionValues.forEach(function(value) {
                    selectOptionType.add(value);
                });
                selectOptionType.bindAddButton();
                break;
        }

        if (data.price_type) {
            Array.from(document.getElementById('<?php echo $this->getFieldId() ?>_'+data.option_id+'_price_type').options).forEach(function(option){
                if (option.value==data.price_type) option.selected = true;
            });
        }

    },
    bindSelectInputType : function(){
        var types = document.querySelectorAll('.select-product-option-type');
        for(var i=0;i<types.length;i++){
            if(!types[i].binded){
                types[i].binded = true;
                types[i].addEventListener('change', function(event){
                    productOptionType.loadStepTwo(event);
                });
            }
        }
    }
}

var productOptionScope = {
    addScope : function(event){
        var element = event.target;
        fieldToDisable = document.getElementById(element.getAttribute('id').replace('_use_default', ''));

        if (fieldToDisable.disabled) {
            if (fieldToDisable.classList.contains('product-option-price')) {//need change to cheking value of element
                document.getElementById(fieldToDisable.getAttribute('id')+'_type').disabled = false;
            }
            fieldToDisable.disabled = false;
        } else {
            if (fieldToDisable.classList.contains('product-option-price')) {//need change to cheking value of element
                document.getElementById(fieldToDisable.getAttribute('id')+'_type').disabled = true;
            }
            fieldToDisable.disabled = true;
        }
    },
    bindScopeCheckbox : function(){
        var checkboxes = document.querySelectorAll('.product-option-scope-checkbox');
        for (var i=0;i<checkboxes.length;i++) {
            if (!checkboxes[i].binded) {
                checkboxes[i].binded = true;
                checkboxes[i].addEventListener('click', this.addScope.bind(this));
            }
        }
    }
}

if(document.getElementById('option_panel')){
    document.getElementById('option_panel').remove();
}

if(document.getElementById('<?php echo $this->getAddButtonId() ?>')){
    document.getElementById('<?php echo $this->getAddButtonId() ?>').addEventListener('click', productOption.add.bind(productOption));
}

//validation for selected input type
Validation.addAllThese([
    ['required-option-select', <?php echo $this->helper('core')->jsonEncode(Mage::helper('catalog')->__('Select type of option')) ?>, function(v, elm) {
        if (elm.value == '') {
            return false;
        }
        return true;
}]]);

//adding data to templates
<?php foreach ($this->getOptionValues() as $_value): ?>
    productOption.add(<?php echo $_value->toJson() ?>);
    productOptionType.addDataToValues(<?php echo $_value->toJson() ?>);
<?php endforeach ?>

productOption.bindRemoveButtons();

//bind scope checkboxes
productOptionScope.bindScopeCheckbox();
//]]>
</script>

<div><?php if (!$this->isReadonly()):?><input type="hidden" name="affect_product_custom_options" value="1" /><?php endif ?></div>

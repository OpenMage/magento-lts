var WidgetInstance = {
    pageGroupTemplate    : pageGroupTemplate,
    pageGroupContainerId : 'page_group_container',
    templatePattern : /\{\{(\w+)\}\}/g,
    count : 0,
    activePageGroups : {},
    selectedItems : {},

    renderPageGroupTemplate : function(data) {
        return this.pageGroupTemplate.replace(this.templatePattern, function(match, key) {
            return data[key] !== undefined && data[key] !== null ? data[key] : '';
        });
    },

    /**
     * Execute <script> elements inside a container (replaces Prototype's String#evalScripts)
     */
    evalScripts : function(container) {
        container.querySelectorAll('script').forEach(function(s) {
            var ns = document.createElement('script');
            if (s.src) {
                ns.src = s.src;
            } else {
                ns.textContent = s.textContent;
            }
            document.head.appendChild(ns);
        });
    },

    addPageGroup : function(data) {
        if (this.pageGroupTemplate && (pageGroupContainer = document.getElementById(this.pageGroupContainerId))) {
            if (!data.page_id) {
                data = {};
                data.page_id = 0;
                data.entities = '';
            }
            data.id = this.count++;
            if (data[data.group + '_entities']) {
                var selected_entities = data[data.group + '_entities'].split(',');
                if (selected_entities.length > 0) {
                    for (var i = 0; i < selected_entities.length; i++) {
                        this.addProductItemToSelection(data.group + '_ids_' + data.id, selected_entities[i]);
                    }
                }
            }
            pageGroupContainer.insertAdjacentHTML('afterbegin', this.renderPageGroupTemplate(data));
            if (data.group) {
                pageGroup = document.getElementById(data.group+'_'+data.id);
                additional = {};
                additional.selectedBlock = data.block;
                additional.selectedTemplate = data.template;
                additional.position = data.position;
                additional.for_value = data.for_value;
                additional.template = '';
                if (data.group == 'pages') {
                    layoutSelect = pageGroup.querySelector('select#layout_handle');
                    if (layoutSelect) {
                        for (var i = 0; i < layoutSelect.options.length; i++) {
                            if (layoutSelect.options[i].value == data.layout_handle) {
                                layoutSelect.options[i].selected = true;
                                break;
                            }
                        }
                    }
                }
                if (document.getElementById(this.pageGroupContainerId+'_'+data.id)) {
                    selectGroupElm = document.getElementById(this.pageGroupContainerId+'_'+data.id).querySelector('select.page_group_select');
                    for (var i = 0; i < selectGroupElm.options.length; i++) {
                        if (selectGroupElm.options[i].value == data.group) {
                            selectGroupElm.options[i].selected = true;
                            break;
                        }
                    }
                }
                forElm = pageGroup.querySelector('input.for_'+data.for_value);
                if (forElm) {
                    /**
                    * IE browsers fix: remove default checked attribute in radio form element
                    * to check others radio form elements in future
                    */
                    pageGroup.querySelector('input.for_all').defaultChecked = false;
                    forElm.defaultChecked = true;
                    forElm.checked = true;
                    this.togglePageGroupChooser(forElm);
                }
                this.displayPageGroup(pageGroup, additional);
            }
        }
    },
    removePageGroup : function(element) {
        container = element.closest('div.page_group_container');
        if (container) {
            container.remove();
        }
    },
    addProductItemToSelection: function(groupId, item) {
        if (undefined == this.selectedItems[groupId]) {
            this.selectedItems[groupId] = {};
        }
        if (!isNaN(parseInt(item))) {
            this.selectedItems[groupId][item] = 1;
        }
    },
    removeProductItemFromSelection: function(groupId, item) {
        if (undefined !== this.selectedItems[groupId]) {
            delete this.selectedItems[groupId][item];
        }
    },
    showBlockContainer : function(container) {
        container = typeof container === 'string' ? document.getElementById(container) : container;
        if (container) {
            container.classList.remove('no-display');
            container.classList.remove('ignore-validate');
            container.style.display = '';
        }
    },
    hideBlockContainer : function(container) {
        container = typeof container === 'string' ? document.getElementById(container) : container;
        if (container) {
            container.classList.add('no-display');
            container.classList.add('ignore-validate');
            container.style.display = 'none';
        }
    },
    displayPageGroup : function(container, additional) {
        container = typeof container === 'string' ? document.getElementById(container) : container;
        if (!container) {
//            if (activePageGroupId = this.activePageGroups[container.closest('div.page_group_container').id]) {
//                this.hideBlockContainer(activePageGroupId);
//            }
        }
        if (!additional) {
            additional = {};
        }
        if (activePageGroupId = this.activePageGroups[container.closest('div.page_group_container').id]) {
            this.hideBlockContainer(activePageGroupId);
        }
        this.activePageGroups[container.closest('div.page_group_container').id] = container.id;
        this.showBlockContainer(container);
        blockContainer = container.querySelector('div.block_reference');
        if (blockContainer && blockContainer.innerHTML == '') {
            layoutHandle = '';
            if (layoutHandleField = container.querySelector('input.layout_handle_pattern')) {
                layoutHandle = layoutHandleField.value;
            }
            this.loadSelectBoxByType('block_reference', container, layoutHandle, additional);
        }
        this.loadSelectBoxByType('block_template', container, additional.selectedBlock, additional);
    },
    displayEntityChooser : function(type, chooser, additional) {
        if (!additional) {
            additional = {};
        }
        if (type == 'categories') {
            additional.url = '<?php echo $this->getCategoriesChooserUrl() ?>';
            additional.post_parameters = {'is_anchor_only':document.getElementById(chooser).querySelector('input.is_anchor_only').value};
        } else if (type == 'products') {
            additional.url = '<?php echo $this->getProductsChooserUrl() ?>';
            additional.post_parameters = {'product_type_id':document.getElementById(chooser).querySelector('input.product_type_id').value};
        }
        if (chooser && additional) {
            this.displayChooser(chooser, additional);
        }
    },
    hideEntityChooser : function(chooser) {
        chooser = document.getElementById(chooser).querySelector('div.chooser');
        if (chooser) {
            chooser.classList.add('no-display');
            chooser.style.display = 'none';
        }
    },
    displayChooser : function(chooser, additional) {
        chooser = document.getElementById(chooser).querySelector('div.chooser');
        entities = chooser.closest('div.chooser_container').querySelector('input[type="text"].entities').value;
        var postParameters = {selected:entities};
        url = '';
        if (additional) {
            if (additional.url) url = additional.url;
            if (additional.post_parameters) {
                Object.keys(additional.post_parameters).forEach(function(key){
                    postParameters[key] = additional.post_parameters[key];
                });
            }
        }
        if (chooser && url) {
            if (chooser.innerHTML == '') {
                postParameters['form_key'] = FORM_KEY;
                fetch(url, {
                    method: 'POST',
                    headers: {'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest'},
                    body: new URLSearchParams(postParameters).toString()
                }).then(function(r) { return r.text(); }).then(function(responseText) {
                    try {
                        if (responseText) {
                            chooser.insertAdjacentHTML('beforeend', responseText);
                            WidgetInstance.evalScripts(chooser);
                            chooser.classList.remove('no-display');
                            chooser.style.display = '';
                        }
                    } catch (e) {
                        console.error(e);
                        alert('<?php echo Mage::helper('core')->jsQuoteEscape(Mage::helper('widget')->__('Error occurs during loading chooser.')) ?>');
                    }
                });
            } else {
                chooser.classList.remove('no-display');
                chooser.style.display = '';
            }
        }
    },
    checkProduct : function(event) {
        var memo = event.memo || (event.detail || {});
        var elm = memo.element,
            container = event.target.closest('div.chooser').closest('div.chooser_container'),
            selectionId = container.id,
            entitiesElm = container.querySelector('input[type="text"].entities');
        if (elm.checked) {
            this.addProductItemToSelection(selectionId, elm.value);
        } else {
            this.removeProductItemFromSelection(selectionId, elm.value);
        }
        if (entitiesElm) {
            entitiesElm.value = Object.keys(this.selectedItems[selectionId]).join(',');
        }
    },
    checkCategory : function(event) {
        var memo = event.memo || (event.detail || {});
        node = memo.node;
        container = event.target.closest('div.chooser_container');
        value = container.querySelector('input[type="text"].entities').value.trim();
        if (node.attributes.checked) {
            if (value) ids = value.split(',');
            else ids = [];
            if (-1 == ids.indexOf(node.id)) {
                ids.push(node.id);
                container.querySelector('input[type="text"].entities').value = ids.join(',');
            }
        } else {
            ids = value.split(',');
            while (-1 != ids.indexOf(node.id)) {
                ids.splice(ids.indexOf(node.id), 1);
                container.querySelector('input[type="text"].entities').value = ids.join(',');
            }
        }
    },
    togglePageGroupChooser : function(element) {
        element = typeof element === 'string' ? document.getElementById(element) : element;
        if (element && (chooser = element.closest('div.group_container').querySelector('div.chooser_container'))) {
            if (element.value == 'all') {
                chooser.classList.add('no-display');
                chooser.style.display = 'none';
            } else {
                chooser.classList.remove('no-display');
                chooser.style.display = '';
            }
        }
    },
    loadSelectBoxByType : function (type, element, value, additional) {
        if (!additional) {
            additional = {};
        }
        if (element && (containerElm = element.querySelector('div.'+type))) {
            url = '';
            selected = '';
            parameters = {};
            if (type == 'block_reference') {
                url = '<?php echo $this->getBlockChooserUrl() ?>';
                if (additional.selectedBlock) {
                    selected = additional.selectedBlock;
                }
                parameters.layout = value;
            } else if (type == 'block_template') {
                url = '<?php echo $this->getTemplateChooserUrl() ?>';
                if (additional.selectedTemplate) {
                    selected = additional.selectedTemplate;
                }
                parameters.block = value;
            }
            parameters.selected = selected;
            parameters.form_key = FORM_KEY;
            if (url) {
                (function(containerElm, element) {
                    fetch(url, {
                        method: 'POST',
                        headers: {'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest'},
                        body: new URLSearchParams(parameters).toString()
                    }).then(function(r) { return r.text(); }).then(function(responseText) {
                        try {
                            if (responseText) {
                                containerElm.innerHTML = responseText;
                                formElm = containerElm.querySelector('select, input[type="hidden"]');
                                if (formElm) {
                                    formElm.name = element.querySelector('input.container_name').value+'['+formElm.name+']';
                                }
                            }
                        } catch (e) {
                            console.error(e);
                            alert('<?php echo Mage::helper('core')->jsQuoteEscape(Mage::helper('widget')->__('Error occurs during loading chooser.')) ?>');
                        }
                    });
                })(containerElm, element);
            }
        }
    }
};

Ext.onReady(function(){
    <?php foreach ($this->getPageGroups() as $pageGroup): ?>
        WidgetInstance.addPageGroup(<?php echo Zend_Json::encode($pageGroup) ?>);
    <?php endforeach ?>
    document.addEventListener('product:changed', function(event){
        WidgetInstance.checkProduct(event);
    });
    document.addEventListener('node:changed', function(event){
        WidgetInstance.checkCategory(event);
    });
});

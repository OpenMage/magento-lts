<div id="checkout-paypaliframe-load" class="authentication"></div>
<script type="text/javascript">
//<![CDATA[
Review.prototype.save = function() {
    if (checkout.loadWaiting!=false) return;
    checkout.setLoadWaiting('review');
    var params = new URLSearchParams(new FormData(payment.form)).toString();
    if (this.agreementsForm) {
        params += '&'+new URLSearchParams(new FormData(this.agreementsForm)).toString();
    }
    var self = this;
    fetch(this.saveUrl, {
        method: 'POST',
        headers: {'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest'},
        body: params + '&save=true'
    }).then(function(resp) { return resp.text(); }).then(function(responseText) {
        var response;
        try { response = JSON.parse(responseText); } catch(e) { response = {}; }
        if (response.error_messages) {
            checkout.setLoadWaiting(false);
        }
        if (self.onSave) {
            self.onSave({responseText: responseText, responseJSON: response});
        }
    }).catch(function() {
        checkout.ajaxFailure();
    });
}
//]]>
</script>

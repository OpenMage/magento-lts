<config>
    <modules>
        <Mage_Authorizenet>
            <version>1.5.0.0</version>
        </Mage_Authorizenet>
    </modules>
    <global>
        <models>
            <authorizenet>
                <class>Mage_Authorizenet_Model</class>
            </authorizenet>
        </models>
        <helpers>
            <authorizenet>
                <class>Mage_Authorizenet_Helper</class>
            </authorizenet>
        </helpers>
    </global>

    <adminhtml>
        <translate>
            <modules>
                <Mage_Authorizenet>
                    <files>
                        <default>Mage_Authorizenet.csv</default>
                    </files>
                </Mage_Authorizenet>
            </modules>
        </translate>
    </adminhtml>

    <frontend>
        <translate>
            <modules>
                <Mage_Authorizenet>
                    <files>
                        <default>Mage_Authorizenet.csv</default>
                    </files>
                </Mage_Authorizenet>
            </modules>
        </translate>
        <routers>
            <authorizenet>
                <use>standard</use>
                <args>
                    <module>Mage_Authorizenet</module>
                    <frontName>authorizenet</frontName>
                </args>
            </authorizenet>
        </routers>
    </frontend>

    <admin>
        <routers>
            <adminhtml>
                <args>
                    <modules>
                        <Mage_Authorizenet before="Mage_Adminhtml">Mage_Authorizenet_Adminhtml</Mage_Authorizenet>
                    </modules>
                </args>
            </adminhtml>
        </routers>
    </admin>
</config>

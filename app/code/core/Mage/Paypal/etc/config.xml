<config>
    <modules>
        <Mage_Paypal>
            <version>2.0.1.0</version>
        </Mage_Paypal>
    </modules>
    <global>
        <models>
            <paypal>
                <class>Mage_Paypal_Model</class>
                <resourceModel>paypal_resource</resourceModel>
            </paypal>
            <paypal_resource>
                <class>Mage_Paypal_Model_Resource</class>
                <entities>
                    <debug>
                        <table>paypal_debug</table>
                    </debug>
                    <webhook_event>
                        <table>paypal_webhook_event</table>
                    </webhook_event>
                </entities>
            </paypal_resource>
        </models>
        <blocks>
            <paypal>
                <class>Mage_Paypal_Block</class>
            </paypal>
        </blocks>
        <helpers>
            <paypal>
                <class>Mage_Paypal_Helper</class>
            </paypal>
        </helpers>
        <sales>
            <order>
                <states>
                    <processing>
                        <visible_on_front>1</visible_on_front>
                    </processing>
                    <pending_payment>
                        <visible_on_front>1</visible_on_front>
                    </pending_payment>
                </states>
            </order>
        </sales>
        <resources>
            <paypal_setup>
                <setup>
                    <module>Mage_Paypal</module>
                    <class>Mage_Paypal_Model_Resource_Setup</class>
                </setup>
                <connection>
                    <use>core_setup</use>
                </connection>
            </paypal_setup>
            <paypal_write>
                <connection>
                    <use>core_write</use>
                </connection>
            </paypal_write>
            <paypal_read>
                <connection>
                    <use>core_read</use>
                </connection>
            </paypal_read>
        </resources>
    </global>
    <frontend>
        <routers>
            <paypal>
                <use>standard</use>
                <args>
                    <module>Mage_Paypal</module>
                    <frontName>paypal</frontName>
                </args>
            </paypal>
        </routers>
        <translate>
            <modules>
                <Mage_Paypal>
                    <files>
                        <default>Mage_Paypal.csv</default>
                    </files>
                </Mage_Paypal>
            </modules>
        </translate>
        <layout>
            <updates>
                <paypal>
                    <file>paypal.xml</file>
                </paypal>
            </updates>
        </layout>
    </frontend>
    <adminhtml>
        <translate>
            <modules>
                <Mage_Paypal>
                    <files>
                        <default>Mage_Paypal.csv</default>
                    </files>
                </Mage_Paypal>
            </modules>
        </translate>
    </adminhtml>
    <admin>
        <routers>
            <adminhtml>
                <args>
                    <modules>
                        <Mage_Paypal before="Mage_Adminhtml">Mage_Paypal_Adminhtml</Mage_Paypal>
                    </modules>
                </args>
            </adminhtml>
        </routers>
    </admin>
    <default>
        <payment>
            <paypal>
                <model>paypal/paypal</model>
                <title>PayPal Express Checkout</title>
                <merchant_country>US</merchant_country>
                <active>0</active>
                <sandbox_mode>1</sandbox_mode>
                <payment_action>capture</payment_action>
                <debug>0</debug>
                <webhook_enabled>0</webhook_enabled>
                <webhook_id></webhook_id>
                <webhook_process_async>1</webhook_process_async>
                <webhook_retry_limit>10</webhook_retry_limit>
                <webhook_retention_days>90</webhook_retention_days>
                <api_timeout>0</api_timeout>
                <retry_enabled>0</retry_enabled>
                <retry_count>0</retry_count>
                <retry_interval>1</retry_interval>
                <retry_backoff_factor>2</retry_backoff_factor>
                <retry_max_wait_time>0</retry_max_wait_time>
                <retry_on_timeout>1</retry_on_timeout>
                <retry_status_codes>408,413,429,500,502,503,504,521,522,524</retry_status_codes>
                <retry_http_methods>GET,PUT</retry_http_methods>
                <button_shape>rect</button_shape>
                <button_color>gold</button_color>
                <button_layout>vertical</button_layout>
                <button_label>paypal</button_label>
                <button_message>1</button_message>
            </paypal>
            <paypal_express>
                <model>paypal/legacy_express</model>
                <title>PayPal Express Checkout (Legacy)</title>
                <active>0</active>
                <group>paypal_legacy</group>
            </paypal_express>
            <paypal_express_bml>
                <model>paypal/legacy_expressBml</model>
                <title>PayPal Credit (Legacy)</title>
                <active>0</active>
                <group>paypal_legacy</group>
            </paypal_express_bml>
            <paypal_direct>
                <model>paypal/legacy_direct</model>
                <title>PayPal Payments Pro (Legacy)</title>
                <active>0</active>
                <group>paypal_legacy</group>
            </paypal_direct>
            <paypal_standard>
                <model>paypal/legacy_standard</model>
                <title>PayPal Website Payments Standard (Legacy)</title>
                <active>0</active>
                <group>paypal_legacy</group>
            </paypal_standard>
            <paypaluk_express>
                <model>paypal/legacy_uk_express</model>
                <title>PayPal Express Checkout Payflow Edition (Legacy)</title>
                <active>0</active>
                <group>paypal_legacy</group>
            </paypaluk_express>
            <paypaluk_express_bml>
                <model>paypal/legacy_uk_expressBml</model>
                <title>PayPal Credit Payflow Edition (Legacy)</title>
                <active>0</active>
                <group>paypal_legacy</group>
            </paypaluk_express_bml>
            <paypaluk_direct>
                <model>paypal/legacy_uk_direct</model>
                <title>PayPal Payments Pro Payflow Edition (Legacy)</title>
                <active>0</active>
                <group>paypal_legacy</group>
            </paypaluk_direct>
            <verisign>
                <model>paypal/legacy_payflow_pro</model>
                <title>Payflow Pro (Legacy)</title>
                <active>0</active>
                <group>paypal_legacy</group>
            </verisign>
            <paypal_billing_agreement>
                <model>paypal/legacy_billingAgreement</model>
                <title>PayPal Billing Agreement (Legacy)</title>
                <active>0</active>
                <group>paypal_legacy</group>
            </paypal_billing_agreement>
            <payflow_link>
                <model>paypal/legacy_payflow_link</model>
                <title>Payflow Link (Legacy)</title>
                <active>0</active>
                <group>paypal_legacy</group>
            </payflow_link>
            <payflow_advanced>
                <model>paypal/legacy_payflow_advanced</model>
                <title>Payflow Advanced (Legacy)</title>
                <active>0</active>
                <group>paypal_legacy</group>
            </payflow_advanced>
            <hosted_pro>
                <model>paypal/legacy_hostedPro</model>
                <title>Hosted Payments Pro (Legacy)</title>
                <active>0</active>
                <group>paypal_legacy</group>
            </hosted_pro>
            <paypal_wps_express>
                <model>paypal/legacy_wps_express</model>
                <title>PayPal Express Checkout (Legacy WPS)</title>
                <active>0</active>
                <group>paypal_legacy</group>
            </paypal_wps_express>
            <groups>
                <paypal_legacy>PayPal (Legacy)</paypal_legacy>
            </groups>
        </payment>
    </default>
    <crontab>
        <jobs>
            <paypal_check_authorization_expiry>
                <schedule>
                    <cron_expr>0 */3 * * *</cron_expr>
                </schedule>
                <run>
                    <model>paypal/cron::processAuthorizationLifecycle</model>
                </run>
            </paypal_check_authorization_expiry>
            <paypal_process_webhook_events>
                <schedule>
                    <cron_expr>*/5 * * * *</cron_expr>
                </schedule>
                <run>
                    <model>paypal/cron::processWebhookEvents</model>
                </run>
            </paypal_process_webhook_events>
        </jobs>
    </crontab>
</config>

# FedEx REST API functional-harness config

# Copy to `.env.fedex` (in this directory) and fill in the values
# from your developer console projects at https://developer.fedex.com.

# ----- Rates & Ship project (OAuth) -----
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=

# ----- Track project (OAuth) -----
FEDEX_TRACKING_CLIENT_ID=
FEDEX_TRACKING_CLIENT_SECRET=

# ----- FedEx account -----
# Use FedEx's published sandbox account when hitting the sandbox. Set your real account for
# production runs.
FEDEX_ACCOUNT=740561073

# ----- Endpoint -----
# 1 = apis-sandbox.fedex.com, 0 = apis.fedex.com.
# Note: Shipment Tests do not run in production mode
FEDEX_SANDBOX_MODE=1
